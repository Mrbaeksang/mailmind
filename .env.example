# MailMind — copy to .env and fill in. NEVER commit the real .env.
# Real values belong in Secret Manager in deployment; .env is local dev only.

# --- Google Cloud / Gemini (Vertex AI via ADC — no API key in repo) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Use Vertex AI (Application Default Credentials), not an API key:
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-3.5-flash          # latest GA (2026-05). gemini-3.1-pro for higher quality.

# --- Embeddings (Google-provided, per MongoDB track rules) ---
EMBEDDING_MODEL=gemini-embedding-2     # latest GA (verify exact API id, may be -preview suffix)
EMBEDDING_DIM=3072                     # default; MRL also supports 1536 / 768

# --- Gmail official MCP (Developer Preview) — test account ONLY ---
GMAIL_MCP_ENDPOINT=https://gmailmcp.googleapis.com/mcp/v1
# OAuth for the dedicated test Gmail account (scopes: gmail.readonly, gmail.compose)
GMAIL_OAUTH_CREDENTIALS=./secrets/gmail_oauth_client.json
GMAIL_OAUTH_TOKEN=./secrets/gmail_token.json

# --- MongoDB Atlas (M0) ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=mailmind
# MongoDB MCP server hardening (disable destructive tools for the agent):
MDB_MCP_DISABLED_TOOLS=drop-database,drop-collection,delete-many,delete-one,atlas
